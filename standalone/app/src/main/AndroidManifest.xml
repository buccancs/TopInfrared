<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.topinfrared.tc001.standalone">

    <!-- USB permissions for TC001 device -->
    <uses-permission android:name="android.permission.USB_PERMISSION" />
    <uses-feature android:name="android.hardware.usb.host" android:required="true" />
    
    <!-- Storage permissions for local recording -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    
    <!-- Camera permissions -->
    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:name=".TC001Application"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.TC001Standalone"
        android:requestLegacyExternalStorage="true">
        
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <activity
            android:name=".ThermalActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
            
        <activity
            android:name=".LocalFilesActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
            
        <!-- USB device filter for TC001 -->
        <receiver android:name=".usb.UsbReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
                <action android:name="android.hardware.usb.action.USB_DEVICE_DETACHED" />
                <action android:name="com.topinfrared.tc001.USB_PERMISSION" />
            </intent-filter>
        </receiver>
        
        <meta-data android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
            android:resource="@xml/device_filter" />

    </application>

</manifest>