<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".ThermalActivity">

    <!-- Back Button -->
    <Button
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="@drawable/circle_button_background"
        android:text="←"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/progressLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="@android:color/white"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Thermal Image View with Overlay -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:background="#222222"
        app:layout_constraintBottom_toTopOf="@id/thermalControls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <ImageView
            android:id="@+id/ivThermalView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Thermal View"
            android:scaleType="fitCenter" />

        <com.topinfrared.tc001.standalone.ui.ThermalOverlayView
            android:id="@+id/thermalOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <!-- Thermal Controls -->
    <LinearLayout
        android:id="@+id/thermalControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Temperature Measurement Mode -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTempModePoint"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="#FF9800"
                android:text="Point"
                android:textColor="@android:color/white"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnTempModeLine"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:backgroundTint="#9E9E9E"
                android:text="Line"
                android:textColor="@android:color/white"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnTempModeArea"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#9E9E9E"
                android:text="Area"
                android:textColor="@android:color/white"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCapture"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="#4CAF50"
                android:text="Capture"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnRecord"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#F44336"
                android:text="Record"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- Standard Recording Duration -->
        <TextView
            android:id="@+id/tvRecordingDuration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Recording: 00:00"
            android:textColor="#F44336"
            android:textSize="14sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- Enhanced Recording Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSamsung4K"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:backgroundTint="#673AB7"
                android:text="Samsung 4K"
                android:textColor="@android:color/white"
                android:textSize="10sp" />

            <Button
                android:id="@+id/btnDngRawL3"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="2dp"
                android:layout_weight="1"
                android:backgroundTint="#E91E63"
                android:text="DNG RAW L3"
                android:textColor="@android:color/white"
                android:textSize="10sp" />

            <Button
                android:id="@+id/btnParallelRec"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:backgroundTint="#FF5722"
                android:text="Parallel"
                android:textColor="@android:color/white"
                android:textSize="10sp" />

        </LinearLayout>
        
        <!-- Enhanced Recording Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="vertical"
            android:visibility="gone"
            android:id="@+id/enhancedRecordingStatus">

            <TextView
                android:id="@+id/tvSamsung4KStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Samsung 4K: 00:00"
                android:textColor="#673AB7"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvDngRawStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="DNG RAW L3: 00:00"
                android:textColor="#E91E63"
                android:textSize="12sp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Additional Overlay Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnToggleGradient"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:backgroundTint="#607D8B"
                android:tag="true"
                android:text="Gradient"
                android:textColor="@android:color/white"
                android:textSize="10sp" />

            <Button
                android:id="@+id/btnToggleHistory"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:alpha="0.5"
                android:backgroundTint="#607D8B"
                android:tag="false"
                android:text="History"
                android:textColor="@android:color/white"
                android:textSize="10sp" />

            <Button
                android:id="@+id/btnClearHistory"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:backgroundTint="#607D8B"
                android:text="Clear"
                android:textColor="@android:color/white"
                android:textSize="10sp" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>